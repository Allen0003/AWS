# ==========================================
# 敏感資訊與環境變數設定檔（重點保護）
# ==========================================
config.env
.env
*.env
*.pem
*.key

# ==========================================
# Python 自動產生的暫存檔與快取
# ==========================================
__pycache__/
*.py[cod]
*$py.class

# ==========================================
# 虛擬環境（Virtual Environments）
# ==========================================
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# ==========================================
# IDE 與編輯器設定檔
# ==========================================
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# ==========================================
# 日誌與數據庫（自動交易機器人常用）
# ==========================================
*.log
*.sqlite3
*.db