Dockerfile

-------

FROM alpine:latest

# 安裝 aws-cli、bash 以及常見的工具（如 curl）
RUN apk add --no-cache aws-cli bash curl

# 設定工作目錄
WORKDIR /workspace

# 預設啟動 bash
CMD ["/bin/bash"]


-------



docker build -t aws-env .


進到容器裡面

docker run -it \
  --name aws-builder \
  -v "$(pwd)":/workspace \
  -v "$HOME/.aws":/root/.aws \
  aws-env



重新使用

# 1. 讓 aws-builder 重新開機
docker start aws-builder

# 2. 進入（附著）到這個容器的 bash 畫面
docker exec -it aws-builder /bin/bash


